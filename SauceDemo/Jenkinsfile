pipeline {
    agent any
    
    stages {
        stage('Build & Run Tests') {
            steps {
                // Navigates into the subfolder to find your pom.xml
                dir('SauceDemo') {
                    bat 'mvn clean test'
                }
            }
        }
    }

    // Single post block handles everything after execution
    post {
        always {
            echo 'Pipeline execution completed'
            
            // Points Jenkins specifically to the nested target directory to find the reports
            testng targetDir: 'SauceDemo/target/surefire-reports', reportFilenamePattern: 'testng-results.xml'
        }
        success {
            echo 'Build and tests successful'
        }
        failure {
            echo 'Build or tests failed'
        }
    }
}